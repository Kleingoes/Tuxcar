{
  "kind": "collectionType",
  "collectionName": "vehiculos",
  "info": {
    "singularName": "vehiculo",
    "pluralName": "vehiculos",
    "displayName": "Vehiculo"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "descripcion": {
      "type": "blocks"
    },
    "Imagen": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "color": {
      "type": "string"
    },
    "kilometraje": {
      "type": "biginteger",
      "required": true,
      "unique": false,
      "min": "0"
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "sedan",
        "pickup",
        "suv",
        "hatchback",
        "van",
        "coupe"
      ]
    },
    "nombre": {
      "type": "string",
      "required": true
    },
    "marca": {
      "type": "string"
    },
    "modelo": {
      "type": "string"
    },
    "transmision": {
      "type": "enumeration",
      "enum": [
        "manual",
        "automatica"
      ]
    },
    "estatus": {
      "type": "enumeration",
      "enum": [
        "vendido",
        "apartado",
        "disponible"
      ]
    },
    "concesionaria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::concesionaria.concesionaria",
      "inversedBy": "vehiculos"
    },
    "ventas": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::venta.venta",
      "mappedBy": "vehiculo"
    },
    "precio": {
      "type": "decimal",
      "required": true,
      "unique": true,
      "default": 0,
      "min": 0
    },
    "anio": {
      "type": "biginteger"
    },
    "numero_serie": {
      "type": "string",
      "required": false,
      "unique": false
    },
    "combustible": {
      "type": "enumeration",
      "enum": [
        "diesel",
        "hibrido",
        "gasolina"
      ]
    },
    "puertas": {
      "type": "integer"
    },
    "disponible": {
      "type": "boolean"
    }
  }
}
